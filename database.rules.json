{
  "rules": {
    "usuarios": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "nomina": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('usuarios').child(auth.uid).child('rol').val() === 'RRHH'"
    },
    "egresados": {
      ".read": "auth != null && root.child('usuarios').child(auth.uid).child('rol').val() === 'RRHH'",
      ".write": "auth != null && root.child('usuarios').child(auth.uid).child('rol').val() === 'RRHH'"
    },
    "dias": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "cierres": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('usuarios').child(auth.uid).child('rol').val() === 'RRHH'"
    }
  }
}
